# ============================================================
# .env.production.example
#
# Copy this file to .env.production on your OCI VM and fill in
# the actual values. Keep this file out of version control.
#
# Usage with docker compose:
#   docker compose --env-file .env.production up -d
# ============================================================

# --- GHCR Image references (set by GitHub Actions automatically) ---
# Replace YOUR_GITHUB_USER with your actual GitHub username
GHCR_IMAGE_WEB=ghcr.io/YOUR_GITHUB_USER/pharmacy-saas-web:latest
GHCR_IMAGE_LINEBOT=ghcr.io/YOUR_GITHUB_USER/pharmacy-saas-linebot:latest

# --- Admin user for initial setup ---
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Session secret (must be at least 32 characters, random string) ---
# Generate with: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_TO_A_RANDOM_32_CHAR_STRING

# --- LINE Bot credentials (get from LINE Developers console) ---
LINE_CHANNEL_ACCESS_TOKEN=YOUR_LINE_CHANNEL_ACCESS_TOKEN
LINE_CHANNEL_SECRET=YOUR_LINE_CHANNEL_SECRET
