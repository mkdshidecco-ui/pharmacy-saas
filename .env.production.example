# ============================================================
# .env.production.example
#
# このファイルをOCI VMに .env.production としてコピーし、
# 実際の値を設定してください。
# このファイル自体には絶対に実際の値を書かないでください。
#
# Usage:
#   cp .env.production.example .env.production
#   vi .env.production   # 実際の値を設定
#   docker compose --env-file .env.production up -d
# ============================================================

# --- GHCR Image references (GitHub Actionsで自動設定) ---
# GitHub ユーザー名に応じて変更してください
GHCR_IMAGE_WEB=ghcr.io/YOUR_GITHUB_USER/pharmacy-saas-web:latest
GHCR_IMAGE_LINEBOT=ghcr.io/YOUR_GITHUB_USER/pharmacy-saas-linebot:latest

# --- スーパー管理者ログイン情報 ---
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=

# --- セッション暗号化シークレット（32文字以上のランダム文字列）---
# 生成コマンド: openssl rand -hex 32
SESSION_SECRET=

# --- LINE Bot 認証情報 (LINE Developers Console から取得) ---
# https://developers.line.biz/console/
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

