// テナントDB: テナントごとのデータ管理
// 重要: 在庫数は Float (小数点2桁・マイナス対応)
// 重要: visitInterval = 0 は「来店不要（非アクティブ）」を意味する

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/tenant-client"
}

datasource db {
  provider = "sqlite"
  url      = env("TENANT_DATABASE_URL")
}

// テナントユーザー
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcryptハッシュ
  name      String
  role      String   @default("staff") // owner / staff
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 顧客
// visitInterval = 0 → 来店不要フラグ（カレンダー・予測計算から除外）
model Customer {
  id            String                @id @default(uuid())
  name          String
  visitInterval Int                   // 来店周期（日）。0=来店不要
  lastVisitDate DateTime?             // 最終来店日（周期繰り返し計算の起点）
  nextVisitDate DateTime              // 次回来店予定日（後方互換性維持）
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  requirements  CustomerRequirement[]
  visitRecords  VisitRecord[]
}

// 商品
// currentStock は Float: 小数点以下2桁・マイナス値対応
model Product {
  id           String                @id @default(uuid())
  name         String
  currentStock Float                 // 在庫数（小数・マイナス対応）
  unit         String?               // 単位（任意: 個, g, ml など）
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  requirements CustomerRequirement[]
  purchases    PurchaseRecord[]
  visitItems   VisitRecordItem[]
  disposals    DisposalRecord[]
}

// 顧客希望商品
// quantity は Float: 小数対応
model CustomerRequirement {
  id         String   @id @default(uuid())
  customerId String
  productId  String
  quantity   Float    // 希望数量（小数対応）
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
}

// 仕入れ記録
// quantity は Float
model PurchaseRecord {
  id          String   @id @default(uuid())
  productId   String
  quantity    Float    // 仕入れ数量（小数対応）
  wholesaler  String
  purchasedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// 来店記録
model VisitRecord {
  id         String            @id @default(uuid())
  customerId String
  visitedAt  DateTime          @default(now())
  createdAt  DateTime          @default(now())
  customer   Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items      VisitRecordItem[]
}

// 来店商品明細
// quantity は Float
model VisitRecordItem {
  id            String      @id @default(uuid())
  visitRecordId String
  productId     String
  quantity      Float       // 実売数量（小数対応）
  createdAt     DateTime    @default(now())
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  visitRecord   VisitRecord @relation(fields: [visitRecordId], references: [id], onDelete: Cascade)
}

// 廃棄記録
// quantity は Float
model DisposalRecord {
  id          String   @id @default(uuid())
  productId   String
  quantity    Float    // 廃棄数量（小数対応）
  reason      String?
  disposedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}
